{
  "extends": ["stylelint-config-standard", "stylelint-config-recommended-vue"],
  "rules": {
    "no-descending-specificity": null,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "theme",
          "custom-variant",
          "import"
        ]
      }
    ],
    "import-notation": null,
    "declaration-empty-line-before": null,
    "selector-class-pattern": null
  }
}
